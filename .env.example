# CyberTabletop environment configuration
# Copy this file to .env and replace every CHANGE_ME value before deployment.
# Never commit .env.

# Application
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://localhost
CORS_ORIGINS=https://localhost

# Docker host binding
# Keep loopback for local development. Use 0.0.0.0 only behind a trusted edge/proxy.
HTTP_BIND=127.0.0.1
HTTP_PORT=80
HTTPS_BIND=127.0.0.1
HTTPS_PORT=443

# PostgreSQL
POSTGRES_USER=cybertabletop
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=cybertabletop
DATABASE_URL=postgresql://cybertabletop:CHANGE_ME_DB_PASSWORD@localhost:5432/cybertabletop

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Secrets
# Use long random values. 64+ characters is recommended for JWT secrets.
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_MIN_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_LONG_RANDOM_SECRET_MIN_64_CHARS
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# Registration
REQUIRE_INVITE=true
INVITE_CODE=CHANGE_ME_LONG_RANDOM_INVITE_CODE

# AI provider
# Options: scripted, claude, ollama
AI_PROVIDER=scripted

# Anthropic Claude, required only when AI_PROVIDER=claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-6

# Ollama, required only when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# SSO / OIDC, leave blank to disable SSO
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://localhost/api/auth/sso/callback

# Logging
LOG_LEVEL=info

